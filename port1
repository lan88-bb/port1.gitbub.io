      <button class="panel__tab" aria-expanded="false">
        <span class="panel__index">02</span>
        <span class="panel__label">平面设计 · GRAPHIC DESIGN</span>
        <span class="panel__arrow">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M17 7H9M17 7V15"/></svg>
