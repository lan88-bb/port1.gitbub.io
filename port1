  <script>
    const panels = document.querySelectorAll('.panel');
    const activeMeta = document.getElementById('active-meta');

    function setActive(panel){
      panels.forEach(p => {
        const active = p === panel;
        p.classList.toggle('is-active', active);
        p.querySelector('.panel__tab').setAttribute('aria-expanded', active);
      });
      activeMeta.textContent = panel.dataset.meta;
    }

    panels.forEach(panel => {
      const tab = panel.querySelector('.panel__tab');
      panel.addEventListener('mouseenter', () => setActive(panel));
      tab.addEventListener('click', () => setActive(panel));
      tab.addEventListener('focus', () => setActive(panel));
    });
  </script>

