<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>个人作品集 · Portfolio</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700;9..144,900&family=Noto+Serif+SC:wght@500;600;700;900&family=Inter:wght@400;500;600&family=Noto+Sans+SC:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root{
    --paper:#F5F2EA;
    --ink:#2B2722;
    --clay:#C96F4A;
    --sand:#ECE3D2;
    --moss:#DCE3D1;
    --moss-deep:#7E8C6B;
    --rose:#EAD9CC;
    --slate:#7C93A6;
  }

  *{margin:0;padding:0;box-sizing:border-box;}
  html,body{height:100%;}

  body{
    font-family:'Inter','Noto Sans SC',sans-serif;
    background:var(--paper);
    color:var(--ink);
    -webkit-font-smoothing:antialiased;
    display:flex;
    flex-direction:column;
    height:100vh;
    height:100dvh;
    overflow:hidden;
    line-height:1.6;
  }

  /* ===================== Top bar ===================== */
  .topbar{
    flex:0 0 auto;
    display:flex;
    align-items:center;
    justify-content:space-between;
    height:56px;
    padding:0 28px;
    border-bottom:1px solid rgba(43,39,34,0.1);
  }
  .topbar__brand{
    font-family:'Fraunces','Noto Serif SC',serif;
    font-weight:600;
    font-size:1.05rem;
    letter-spacing:0.01em;
  }
  .topbar__brand span{ color:var(--clay); }
  .topbar__status{
    display:flex;
    align-items:center;
    gap:10px;
    font-family:'JetBrains Mono',monospace;
    font-size:0.72rem;
    letter-spacing:0.14em;
    text-transform:uppercase;
    color:color-mix(in srgb, currentColor 55%, transparent);
  }
  .topbar__status .dot{
    width:6px;height:6px;border-radius:50%;
    background:var(--clay);
    animation:pulse 2.6s ease-in-out infinite;
  }
  @keyframes pulse{0%,100%{opacity:1;}50%{opacity:.25;}}

  /* ===================== Spine / panels ===================== */
  .spine{
    flex:1 1 auto;
    min-height:0;
    display:flex;
    flex-direction:row;
    width:100%;
  }

  .panel{
    position:relative;
    display:flex;
    flex-direction:row;
    flex-grow:1;
    flex-shrink:1;
    flex-basis:0;
    min-width:84px;
    overflow:hidden;
    color:var(--ink);
    border-right:1px solid color-mix(in srgb, currentColor 12%, transparent);
    background:var(--paper);
    transition:flex-grow .7s cubic-bezier(.22,.61,.36,1);
    cursor:pointer;
    opacity:0;
    transform:translateY(18px);
    animation:panelIn .6s ease-out forwards;
  }
  .panel:last-of-type{ border-right:none; }
  .panel:nth-of-type(1){ animation-delay:.02s; }
  .panel:nth-of-type(2){ animation-delay:.08s; }
  .panel:nth-of-type(3){ animation-delay:.14s; }
  .panel:nth-of-type(4){ animation-delay:.20s; }
  .panel:nth-of-type(5){ animation-delay:.26s; }
  @keyframes panelIn{ to{ opacity:1; transform:translateY(0); } }

  .panel.is-active{ flex-grow:14; cursor:default; }

  .panel--about{ background:var(--ink); color:var(--paper); }
  .panel--design{ background:var(--sand); }
  .panel--product{ background:var(--paper); }
  .panel--video{ background:var(--moss); }
  .panel--photo{ background:var(--rose); }

  /* ---- watermark glyph ---- */
  .panel__watermark{
    position:absolute;
    inset:0;
    display:flex;
    align-items:center;
    justify-content:center;
    font-family:'Fraunces','Noto Serif SC',serif;
    font-weight:900;
    font-size:clamp(6rem, 26vw, 20rem);
    line-height:1;
    color:currentColor;
    opacity:0.055;
    white-space:nowrap;
    pointer-events:none;
    transition:transform .8s cubic-bezier(.22,.61,.36,1), font-size .8s cubic-bezier(.22,.61,.36,1), opacity .8s ease;
  }
  .panel.is-active .panel__watermark{
    font-size:clamp(10rem, 32vw, 28rem);
    transform:translate(10%,-6%);
    opacity:0.05;
  }

  /* ---- tab (collapsed label / always-visible rail) ---- */
  .panel__tab{
    flex:0 0 84px;
    display:flex;
    flex-direction:column;
    align-items:center;
    justify-content:space-between;
    padding:26px 0;
    position:relative;
    z-index:2;
    height:100%;
  }
  .panel__index,
  .panel__arrow{
    writing-mode:horizontal-tb;
    font-family:'JetBrains Mono',monospace;
    font-size:0.7rem;
    letter-spacing:0.1em;
    color:color-mix(in srgb, currentColor 55%, transparent);
    display:flex;
    align-items:center;
    justify-content:center;
  }
  .panel__arrow svg{ display:block; transition:transform .5s ease; }
  .panel.is-active .panel__arrow svg{ transform:rotate(135deg); }

  .panel__label{
    writing-mode:vertical-rl;
    transform:rotate(180deg);
    font-family:'Fraunces','Noto Serif SC',serif;
    font-weight:500;
    font-size:clamp(1rem, 1.35vw, 1.4rem);
    letter-spacing:0.05em;
    white-space:nowrap;
  }

  /* ---- content ---- */
  .panel__content{
    flex:1 1 auto;
    min-width:0;
    height:100%;
    overflow:hidden;
    position:relative;
    z-index:2;
  }
  .content-inner{
    height:100%;
    overflow-y:auto;
    padding:48px 56px 64px;
    opacity:0;
    transform:translateX(8px);
    transition:opacity .35s ease .1s, transform .5s ease .1s;
  }
  .panel.is-active .content-inner{
    opacity:1;
    transform:translateX(0);
  }
  .content-inner::-webkit-scrollbar{ width:6px; }
  .content-inner::-webkit-scrollbar-track{ background:transparent; }
  .content-inner::-webkit-scrollbar-thumb{
    background:color-mix(in srgb, currentColor 22%, transparent);
    border-radius:3px;
  }

  .eyebrow{
    font-family:'JetBrains Mono',monospace;
    font-size:0.72rem;
    letter-spacing:0.2em;
    text-transform:uppercase;
    color:color-mix(in srgb, currentColor 55%, transparent);
    margin-bottom:18px;
  }
  .section-title{
    font-family:'Fraunces','Noto Serif SC',serif;
    font-weight:600;
    font-size:clamp(2.2rem, 4.4vw, 4rem);
    line-height:1.1;
    margin-bottom:6px;
  }
  .section-sub{
    font-size:0.95rem;
    color:color-mix(in srgb, currentColor 60%, transparent);
    margin-bottom:32px;
    max-width:52ch;
  }
  .section-sub em{
    display:block;
    font-style:normal;
    font-family:'Inter','Noto Sans SC',sans-serif;
    font-size:0.85rem;
    margin-top:6px;
    color:color-mix(in srgb, currentColor 45%, transparent);
  }

  /* ===================== About panel ===================== */
  .about-role{
    font-size:1.05rem;
    margin-bottom:28px;
    color:color-mix(in srgb, currentColor 75%, transparent);
  }
  .about-bio{
    max-width:58ch;
    font-size:1rem;
    margin-bottom:8px;
  }
  .about-bio + .about-bio{
    font-size:0.88rem;
    color:color-mix(in srgb, currentColor 55%, transparent);
    margin-bottom:36px;
  }
  .now-line{
    display:flex;
    align-items:center;
    gap:10px;
    font-family:'JetBrains Mono',monospace;
    font-size:0.78rem;
    letter-spacing:0.08em;
    text-transform:uppercase;
    margin-bottom:36px;
  }
  .now-line .dot{
    width:7px;height:7px;border-radius:50%;
    background:var(--clay);
    animation:pulse 2.6s ease-in-out infinite;
  }
  .chips{ display:flex; flex-wrap:wrap; gap:8px; margin-bottom:40px; max-width:520px; }
  .chip{
    font-family:'JetBrains Mono',monospace;
    font-size:0.7rem;
    letter-spacing:0.05em;
    text-transform:uppercase;
    padding:7px 14px;
    border:1px solid color-mix(in srgb, currentColor 22%, transparent);
    border-radius:100px;
  }
  .contact-list{
    list-style:none;
    display:flex;
    flex-direction:column;
    gap:0;
    max-width:420px;
  }
  .contact-list li{
    display:flex;
    justify-content:space-between;
    align-items:baseline;
    padding:13px 0;
    border-bottom:1px solid color-mix(in srgb, currentColor 12%, transparent);
    font-size:0.92rem;
  }
  .contact-list li:first-child{ border-top:1px solid color-mix(in srgb, currentColor 12%, transparent); }
  .contact-list .label{
    font-family:'JetBrains Mono',monospace;
    font-size:0.7rem;
    letter-spacing:0.14em;
    text-transform:uppercase;
    color:color-mix(in srgb, currentColor 55%, transparent);
  }

  /* ===================== Cards ===================== */
  .card-grid{
    display:grid;
    grid-template-columns:1fr;
    gap:28px;
    max-width:720px;
  }
  .card{
    display:flex;
    flex-direction:column;
    border:1px solid color-mix(in srgb, currentColor 10%, transparent);
    border-radius:4px;
    overflow:hidden;
    transition:transform .35s cubic-bezier(.22,.61,.36,1), box-shadow .35s ease;
    background:color-mix(in srgb, currentColor 3%, transparent);
  }
  .card:hover, .card:focus-visible{
    transform:translateY(-4px);
    box-shadow:0 14px 28px -16px rgba(0,0,0,0.28);
  }
  .card__media{
    height:clamp(140px, 18vw, 220px);
    width:100%;
  }
  .card--a .card__media{ background:linear-gradient(135deg, var(--clay), var(--sand)); }
  .card--b .card__media{ background:linear-gradient(135deg, var(--moss-deep), var(--moss)); }
  .card--c .card__media{ background:linear-gradient(135deg, var(--ink), var(--clay)); }
  .card--d .card__media{ background:linear-gradient(135deg, var(--slate), var(--rose)); }
  .card__meta{ padding:18px 20px 22px; }
  .card__title{
    font-family:'Fraunces','Noto Serif SC',serif;
    font-weight:600;
    font-size:1.15rem;
    margin-bottom:8px;
  }
  .card__desc{
    font-size:0.88rem;
    color:color-mix(in srgb, currentColor 60%, transparent);
    margin-bottom:14px;
    max-width:46ch;
  }
  .card__tag{
    font-family:'JetBrains Mono',monospace;
    font-size:0.68rem;
    letter-spacing:0.14em;
    text-transform:uppercase;
    color:color-mix(in srgb, currentColor 50%, transparent);
  }

  /* ===================== Footer hint ===================== */
  .foothint{
    flex:0 0 auto;
    height:40px;
    display:flex;
    align-items:center;
    justify-content:center;
    gap:10px;
    font-family:'JetBrains Mono',monospace;
    font-size:0.68rem;
    letter-spacing:0.18em;
    text-transform:uppercase;
    color:color-mix(in srgb, currentColor 55%, transparent);
    border-top:1px solid rgba(43,39,34,0.1);
  }

  /* ===================== Focus ===================== */
  .panel__tab:focus-visible,
  .card:focus-visible{
    outline:2px solid var(--clay);
    outline-offset:-3px;
  }

  /* ===================== Responsive ===================== */
  @media (max-width:860px){
    .topbar{ padding:0 18px; }
    .topbar__status span:last-child{ display:none; }

    .spine{ flex-direction:column; }
    .panel{
      flex-direction:column;
      min-width:auto;
      min-height:56px;
      border-right:none;
      border-bottom:1px solid color-mix(in srgb, currentColor 12%, transparent);
    }
    .panel:last-of-type{ border-bottom:none; }

    .panel__watermark{ font-size:clamp(3.5rem, 28vw, 7rem); }
    .panel.is-active .panel__watermark{
      font-size:clamp(5rem, 34vw, 10rem);
      transform:translate(20%,-10%);
    }

    .panel__tab{
      flex:0 0 56px;
      flex-direction:row;
      align-items:center;
      justify-content:flex-start;
      gap:16px;
      padding:0 20px;
      width:100%;
      height:auto;
    }
    .panel__label{
      writing-mode:horizontal-tb;
      transform:none;
      font-size:1.05rem;
    }
    .panel__arrow{ margin-left:auto; }

    .content-inner{ padding:28px 20px 40px; }
    .section-title{ font-size:2rem; }
    .card__media{ height:180px; }
  }

  @media (prefers-reduced-motion:reduce){
    *{ animation:none !important; transition:none !important; }
    .panel{ opacity:1; transform:none; }
  }
</style>
</head>
